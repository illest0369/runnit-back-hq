{
  "name": "frontend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "lint": "next typegen && tsc --noEmit",
    "build": "next build && npm run build:worker",
    "build:worker": "tsc -p tsconfig.worker.json",
    "start": "next start",
    "worker": "npm --prefix backend start",
    "smoke:v1": "tsx scripts/smoke-v1-flow.ts",
    "smoke:metricool-export": "tsx scripts/smoke-metricool-export-flow.ts",
    "smoke:n8n-export": "tsx scripts/smoke-n8n-export-flow.ts",
    "smoke:source-ingestion": "tsx scripts/smoke-source-ingestion.ts",
    "smoke:transcript-scout": "tsx scripts/smoke-transcript-scout.ts",
    "metricool:probe": "tsx scripts/probe-metricool-config.ts",
    "n8n:probe": "tsx scripts/probe-n8n-config.ts",
    "n8n:help": "tsx scripts/print-n8n-dry-run-help.ts",
    "ingest:youtube-rss": "tsx scripts/ingest-youtube-rss.ts",
    "transcript:video": "tsx scripts/transcript-video.ts",
    "scout:video": "tsx scripts/scout-video.ts",
    "import:apify": "tsx scripts/run-apify-import.ts",
    "source-system:summary": "tsx scripts/source-system-summary.ts",
    "worker:clips": "node dist/workers/startWorker.js",
    "worker:post:dry-run": "node dist/workers/startPostDryRunWorker.js"
  },
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1036.0",
    "@aws-sdk/s3-request-presigner": "^3.1036.0",
    "@google/genai": "^2.0.1",
    "@supabase/supabase-js": "^2.101.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.73.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.1",
    "execa": "^9.6.1",
    "framer-motion": "^12.38.0",
    "ioredis": "^5.10.1",
    "lucide-react": "^1.7.0",
    "next": "15.5.19",
    "postcss": "^8.5.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.1.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  }
}
