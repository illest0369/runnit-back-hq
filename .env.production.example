# Required production app/security
NEXT_PUBLIC_APP_URL=
SESSION_SECRET=
APP_USERS_JSON=[]

# Required production Supabase
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Required for worker queues
REDIS_URL=
# Leave unset in production to use the default rbhq-post queue, unless an
# explicitly coordinated production queue migration is underway.
RBHQ_POST_QUEUE_NAME=
GEMINI_API_KEY=

# Metricool live publishing
# Leave METRICOOL_TEST_MODE=1 for production dry-run. Set to 0 or unset only when live posting is intended.
PUBLISH_PROVIDER=manual
METRICOOL_TEST_MODE=1
METRICOOL_API_URL=https://app.metricool.com/api
METRICOOL_API_KEY=
METRICOOL_USER_ID=
METRICOOL_TIMEZONE=America/Los_Angeles
METRICOOL_BRAND_RB_SPORTS=
METRICOOL_BRAND_RB_ARENA=
METRICOOL_BRAND_RB_WOMEN=
METRICOOL_BRAND_RB_COMBAT=
METRICOOL_BRAND_RB_CFB=

# Mac mini / n8n publishing bridge
# Set PUBLISH_PROVIDER=n8n only after the Mac mini n8n webhook is ready.
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
N8N_TEST_MODE=true
N8N_TIMEOUT_MS=10000

# Source ingestion
APIFY_TOKEN=
APIFY_API_TOKEN=
APIFY_YOUTUBE_ACTOR_ID=
APIFY_TIKTOK_ACTOR_ID=
APIFY_INSTAGRAM_ACTOR_ID=
APIFY_REDDIT_ACTOR_ID=
YOUTUBE_API_KEY=
YT_DLP_COOKIES=

# Clip storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
